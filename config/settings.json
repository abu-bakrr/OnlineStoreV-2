{
	// ============================================================
	//  ШАБЛОН КОНФИГУРАЦИИ ИНТЕРНЕТ-МАГАЗИНА
	//  Меняя поля с пометкой ✏️ — получаете уникальный сайт под бренд.
	//  Поля с пометкой ⚙️ — настройки платформы, обычно не трогаются.
	// ============================================================

	"subscriptionTier": "pro",          // ⚙️ тариф подписки клиента
	"language": "ru",                   // ⚙️ язык интерфейса сайта

	// ---------- 1. БРЕНДИНГ ----------
	"shopName": "My Shop",            // ✏️ название магазина клиента
	"description": "Слоган вашего бренда — коротко и ярко",  // ✏️ слоган
	"logo": "/config/logo.svg",         // ✏️ логотип, светлая тема
	"darkLogo": "/config/logo-dark.svg",// ✏️ логотип, тёмная тема

	// ---------- 2. SEO (как магазин выглядит в Google / Яндексе) ----------
	"seo": {
		"title": "Demo Shop — Категория товаров | Интернет-магазин", // ✏️
		"description": "Demo Shop — короткое описание: что продаёте, для кого, где находитесь.", // ✏️
		"keywords": "категория, товары, бренд, город, ключевые слова", // ✏️
		"siteUrl": "https://demo-shop.example", // ✏️ домен клиента
		"language": "ru" // ⚙️
	},

	// ---------- 3. ВАЛЮТА ----------
	"currency": {
		"symbol": "$",      // ✏️ обозначение валюты клиента
		"code": "$",        // ✏️ код валюты
		"position": "before"   // ⚙️ "after" → 1000 UZS, "before" → UZS 1000
	},

	// ---------- 4. СВЯЗЬ С КЛИЕНТАМИ ----------
	"managerContact": "@your_shop_bot",             // ✏️ телеграм-бот / менеджер
	"telegramBotUrl": "https://t.me/your_shop_bot", // ✏️ ссылка на бота

	// ---------- 5. ЦВЕТА — светлая тема ----------
	// Меняете 6-7 hex-кодов — и весь сайт перекрашивается под бренд.
	"colorScheme": {
		"background": "#FFFFFF",
		"foreground": "#111111",

		"card": "#FFFFFF",
		"cardForeground": "#111111",

		"primary": "#4F46E5",        // ✏️ главный цвет бренда (кнопки, акценты)
		"primaryForeground": "#FFFFFF",

		"secondary": "#7C3AED",      // ✏️ второй цвет бренда
		"secondaryForeground": "#FFFFFF",

		"muted": "#F5F5F7",
		"mutedForeground": "#6B6B6B",

		"accent": "#4F46E5",
		"accentForeground": "#FFFFFF",

		"border": "#E6E6E6",
		"input": "#E6E6E6",
		"ring": "#4F46E5"
	},

	// ---------- 6. ЦВЕТА — тёмная тема ----------
	"colorSchemeDark": {
		"background": "#0F0F0F",
		"foreground": "#F5F5F5",

		"card": "#161616",
		"cardForeground": "#F5F5F5",

		"primary": "#818CF8",
		"primaryForeground": "#0F0F0F",

		"secondary": "#A78BFA",
		"secondaryForeground": "#0F0F0F",

		"muted": "#1F1F1F",
		"mutedForeground": "#9A9A9A",

		"accent": "#818CF8",
		"accentForeground": "#0F0F0F",

		"border": "#262626",
		"input": "#262626",
		"ring": "#818CF8"
	},

	// ---------- 7. СОРТИРОВКА ТОВАРОВ (стандартная) ----------
	"sortOptions": [
		{ "id": "old", "label": "Сначала старые" },
		{ "id": "new", "label": "Сначала новые" },
		{ "id": "price-asc", "label": "Сначала дешевые" },
		{ "id": "price-desc", "label": "Сначала дорогие" }
	],

	// ---------- 8. НАСТРОЙКИ ИНТЕРФЕЙСА (стандартные) ----------
	"ui": {
		"maxWidth": "420px",
		"productsPerPage": 12,
		"showCategoryIcons": true,
		"showPriceFilter": true,
		"showShopName": true
	},

	// ---------- 9. ТЕКСТЫ ИНТЕРФЕЙСА (стандартные, можно адаптировать) ----------
	"texts": {
		"addToCart": "Добавить в корзину",
		"addedToCart": "Добавлено в корзину",
		"checkout": "Оформить заказ",
		"total": "Итого",
		"emptyCart": "Корзина пуста",
		"emptyFavorites": "Нет избранных товаров",
		"loading": "Загрузка..."
	},

	// ---------- 10. ШРИФТЫ ----------
	"fonts": {
		"fontFamily": "Inter",              // ⚙️ основной шрифт текста
		"fontFile": null,
		"shopNameFontFamily": "Montez",     // ✏️ "вывесочный" шрифт под бренд
		"shopNameFontFile": "/config/logo-font.ttf", // ✏️ если шрифт не из Google Fonts
		"shopNameFontSize": 30,
		"productName": { "weight": 700 },
		"price": { "weight": 600 },
		"description": { "weight": 400 }
	},

	"logoSize": 32,        // ⚙️ размер логотипа в хедере
	"logoSizeLarge": 80,   // ⚙️ размер логотипа на крупных экранах

	// ---------- 11. СТАТУСЫ ЗАКАЗОВ (стандартные) ----------
	"orderStatuses": {
		"pending": "Ожидает оплаты",
		"reviewing": "Рассматривается",
		"paid": "Оплачен",
		"processing": "Собирается",
		"shipped": "В пути",
		"delivered": "Доставлен",
		"cancelled": "Отменён"
	}
}
